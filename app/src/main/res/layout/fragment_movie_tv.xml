<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070D">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="#05070D">

                <TextView
                    android:id="@+id/tv_source_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人助手 TV"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:padding="4dp"
                    android:drawableStart="@drawable/ic_source_dot"
                    android:drawablePadding="4dp"
                    android:drawableRight="@drawable/ic_arrow_drop"
                    android:layout_marginEnd="8dp"/>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#0FFFFFFF"
                        android:padding="9dp"
                        android:gravity="center_vertical"
                        android:layout_marginRight="44dp"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2315"
                            android:textColor="#6F7890"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"/>

                        <EditText
                            android:id="@+id/tv_search_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="搜索影视..."
                            android:textColor="#E8EDFF"
                            android:textColorHint="#6F7890"
                            android:textSize="13sp"
                            android:background="@null"
                            android:inputType="text"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/tv_search_history_dropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="44dp"
                        android:background="#0F1923"
                        android:visibility="gone"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_parser"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_electric"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="6dp"/>

                    <ImageButton
                        android:id="@+id/btn_window"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_window"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="6dp"/>

                    <ImageButton
                        android:id="@+id/btn_more"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_plus"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="centerInside"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Category Bar -->
            <HorizontalScrollView
                android:id="@+id/tv_cat_bar_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:id="@+id/tv_cat_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_section_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="推荐"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"
                        android:drawableStart="@drawable/ic_section_line"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/tv_cat_toggle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:layout_marginStart="8dp"/>
            </HorizontalScrollView>

            <!-- Category Dropdown -->
            <FrameLayout
                android:id="@+id/tv_cat_dropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0F1923"
                android:padding="14dp"
                android:visibility="gone"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="-4dp">

                <LinearLayout
                    android:id="@+id/tv_cat_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"/>
            </FrameLayout>

            <!-- Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="0dp">

                <!-- Load Status -->
                <TextView
                    android:id="@+id/tv_load_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#7DD3FC"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:minHeight="18dp"/>

                <!-- Movie Grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/tv_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>

                <!-- Load More -->
                <LinearLayout
                    android:id="@+id/tv_load_more_wrap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/tv_load_more_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加载更多"
                        android:textSize="13sp"
                        android:backgroundTint="#2196F3"/>

                    <TextView
                        android:id="@+id/tv_page_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="第1页"
                        android:textColor="#556677"
                        android:textSize="11sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- Empty Guide -->
                <LinearLayout
                    android:id="@+id/empty_guide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u25B6"
                        android:textColor="#2196F3"
                        android:textSize="48sp"
                        android:alpha="0.6"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="欢迎使用个人助手 TV"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="长按底部主页进入仓库管理，或点击左上角选择站点"
                        android:textColor="#73839D"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="280dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#FFFFFF"
                            android:alpha="0.04"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="#2196F3"
                                android:layout_marginEnd="12dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="长按底部主页打开仓库"
                                android:textColor="#B0B8CC"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#FFFFFF"
                            android:alpha="0.04"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="2"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="#2196F3"
                                android:layout_marginEnd="12dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="选择饭太硬等配置源"
                                android:textColor="#B0B8CC"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#FFFFFF"
                            android:alpha="0.04">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="#2196F3"
                                android:layout_marginEnd="12dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="选择站点和分类观看"
                                android:textColor="#B0B8CC"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Skeleton Screen -->
                <LinearLayout
                    android:id="@+id/skeleton_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:padding="14dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="170dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="#1D3557"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="170dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="#1D3557"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="170dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="#1D3557"/>
                </LinearLayout>

                <!-- Error State -->
                <LinearLayout
                    android:id="@+id/error_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="!"
                        android:textColor="#F87171"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:background="#F87171"
                        android:alpha="0.15"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/error_state_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加载失败"
                        android:textColor="#8792AD"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/error_retry_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="重试"
                        android:backgroundTint="#2196F3"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Pull to Refresh Indicator -->
    <TextView
        android:id="@+id/pull_refresh_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="下拉刷新"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="#2196F3"
        android:padding="6dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone"/>
</FrameLayout>

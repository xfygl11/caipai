<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0F1923"
    android:padding="16dp">

    <EditText
        android:id="@+id/add_source_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API名称"
        android:textColor="#E8EDFF"
        android:textColorHint="#6F7890"
        android:padding="12dp"
        android:background="@drawable/tv_input_bg"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/add_source_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API链接"
        android:textColor="#E8EDFF"
        android:textColorHint="#6F7890"
        android:padding="12dp"
        android:background="@drawable/tv_input_bg"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/add_source_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消"
            android:backgroundTint="#2A4A6A"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/add_source_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="保存"
            android:backgroundTint="#2196F3"/>
    </LinearLayout>
</LinearLayout>

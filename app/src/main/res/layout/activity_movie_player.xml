<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Top Toolbar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111827"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u2190"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#33FFFFFF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingLeft="8dp" />

        <TextView
            android:id="@+id/tv_site"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7C3AED"
            android:textSize="12sp"
            android:gravity="center_vertical" />

        <Button
            android:id="@+id/btn_parser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="解析"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#7C3AED"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_fav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="收藏"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#16A34A"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btn_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#2563EB"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Movie Title Bar -->
    <TextView
        android:id="@+id/tv_movie_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:ellipsize="end"
        android:maxLines="2" />

    <!-- Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000" />

    <!-- Error Overlay -->
    <LinearLayout
        android:id="@+id/error_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1F2937"
        android:padding="16dp"
        android:visibility="gone"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_error_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重试"
            android:textColor="#FFFFFF"
            android:background="#7C3AED" />

        <Button
            android:id="@+id/btn_next_parse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="切换解析"
            android:textColor="#FFFFFF"
            android:background="#2563EB"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Parser Selection Row -->
    <HorizontalScrollView
        android:id="@+id/parser_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:padding="4dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/parser_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Speed Control Row -->
    <LinearLayout
        android:id="@+id/speed_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111827"
        android:padding="4dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_speed_05"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.5x"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#374151"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_speed_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#374151"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_speed_15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5x"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#374151"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_speed_20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2x"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#374151"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Episode List -->
    <LinearLayout
        android:id="@+id/episode_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#05070D">

        <TextView
            android:id="@+id/tv_episode_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选集"
            android:textColor="#7C3AED"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/episode_line_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_episodes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="仓库名称"
        android:textSize="12sp"
        android:textColor="#8899aa"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etDialogName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="例如：饭太硬"
        android:textSize="16sp"
        android:textColor="#fff"
        android:textColorHint="#667788"
        android:background="#1a2735"
        android:padding="12dp"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="仓库地址"
        android:textSize="12sp"
        android:textColor="#8899aa"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etDialogUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="http:// 或 https:// 开头"
        android:textSize="16sp"
        android:textColor="#fff"
        android:textColorHint="#667788"
        android:background="#1a2735"
        android:padding="12dp"
        android:inputType="textUri"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvDialogStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#8899aa"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/btnDialogConfirm"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="确定添加"
        android:textColor="#fff"
        android:textSize="15sp"
        android:background="@color/primary"
        android:clickable="true"/>

</LinearLayout>

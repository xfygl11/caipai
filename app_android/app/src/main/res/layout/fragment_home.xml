<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <TextView
        android:id="@+id/movieLoadStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="12sp"
        android:textColor="#4ade80"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Site name header - clickable to open site select -->
    <TextView
        android:id="@+id/tvSiteName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:text="点击选择站点"
        android:textColor="#ff6b35"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:gravity="center"
        android:visibility="visible"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Skeleton loading placeholder -->
        <LinearLayout
            android:id="@+id/skeletonGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="4dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3"
                android:layout_marginBottom="14dp">
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3"
                android:layout_marginBottom="14dp">
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3">
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#1d3557"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Load more wrapper -->
        <LinearLayout
            android:id="@+id/tvLoadMoreWrap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone"
            android:layout_gravity="bottom">

            <TextView
                android:id="@+id/tvLoadMoreBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载更多"
                android:textColor="#ff6b35"
                android:textSize="14sp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="10dp"
                android:clickable="true"/>

            <TextView
                android:id="@+id/tvPageInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第 1 页"
                android:textColor="#667788"
                android:textSize="12sp"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Main content container - holds RecyclerView + overlays -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Section name header inside the content frame -->
            <TextView
                android:id="@+id/tvSectionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp"
                android:text="推荐"
                android:textColor="#fff"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="visible"/>

            <!-- RecyclerView - bottom layer, always receives touch events -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tvGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="4dp"/>

            <!-- Empty guide - overlay on top of RecyclerView, invisible by default -->
            <LinearLayout
                android:id="@+id/emptyGuide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"
                android:background="@color/background"
                android:focusable="false"
                android:focusableInTouchMode="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9654;"
                    android:textColor="@color/primary"
                    android:textSize="48sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="欢迎使用个人助手 TV"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="长按底部「主页」打开仓库管理，点击站点名称切换站点"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. 长按底部主页打开仓库管理"
                        android:textColor="#b0b8cc"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. 添加仓库URL并解析站点"
                        android:textColor="#b0b8cc"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. 点击站点名称切换到对应站点"
                        android:textColor="#b0b8cc"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Error state - overlay on top of RecyclerView, invisible by default -->
            <LinearLayout
                android:id="@+id/errorState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone"
                android:background="@color/background"
                android:focusable="false"
                android:focusableInTouchMode="false">
                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="!"
                    android:textColor="#f87171"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="#f8717122"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:id="@+id/errorStateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="加载失败"
                    android:textColor="#8792ad"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>
                <Button
                    android:id="@+id/errorRetryBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重试"
                    android:background="@drawable/bg_btn_accent"
                    android:textColor="#fff"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"/>
            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

</LinearLayout>

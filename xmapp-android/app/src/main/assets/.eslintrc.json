{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "semi": ["warn", "always"],
    "eqeqeq": "warn",
    "no-with": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-return-await": "warn",
    "no-console": "off",
    "strict": ["warn", "global"],
    "no-var": "warn",
    "prefer-const": "warn",
    "no-template-curly-in-string": "warn"
  }
}
